{
  "name": "copilot-money-mcp",
  "mcpName": "io.github.ignaciohermosillacornejo/copilot-money-mcp",
  "version": "2.2.0",
  "description": "MCP server for Copilot Money — query personal finances locally (14 cache-mode read tools), opt into GraphQL-backed live reads with --live-reads (21 read tools: 8 cache + 13 live), and manage data via Copilot's GraphQL API (17 write tools, opt-in with --write)",
  "keywords": [
    "mcp",
    "copilot-money",
    "personal-finance",
    "leveldb",
    "firestore",
    "claude",
    "ai"
  ],
  "author": "Ignacio Hermosilla <hello@ignaciohermosilla.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ignaciohermosillacornejo/copilot-money-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ignaciohermosillacornejo/copilot-money-mcp/issues"
  },
  "homepage": "https://github.com/ignaciohermosillacornejo/copilot-money-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "copilot-money-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "PRIVACY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun run src/server.ts",
    "dev:debug": "bun --inspect run src/server.ts",
    "generate:graphql": "bun run scripts/generate-graphql-operations.ts",
    "build": "bun run generate:graphql && bun build src/cli.ts src/server.ts --outdir dist --target node --format esm --external classic-level && bun build src/core/decode-worker.ts --outdir dist --target node --format esm --external classic-level && chmod +x dist/cli.js && cp scripts/launcher.sh dist/launcher.sh && chmod +x dist/launcher.sh",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e/",
    "test:unit": "bun test tests/tools/ tests/core/ tests/models/ tests/utils/",
    "test:integration": "bun test tests/integration/",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run check:version-sync && bun run check:server-json && bun test --bail",
    "snapshot:create": "bun run scripts/snapshot.ts create",
    "snapshot:restore": "bun run scripts/snapshot.ts restore",
    "snapshot:list": "bun run scripts/snapshot.ts list",
    "sync-manifest": "bun run scripts/sync-manifest.ts",
    "check:version-sync": "bun run scripts/check-version-sync.ts",
    "check:server-json": "bun run scripts/check-server-json.ts",
    "check:skills": "python3 scripts/check-skills.py",
    "fix": "bun run lint:fix && bun run format",
    "smoke": "bun run scripts/smoke/conformance.ts",
    "smoke:conformance": "bun run scripts/smoke/conformance.ts",
    "smoke:recurring-frequency": "bun run scripts/smoke/recurring-frequency-conformance.ts",
    "smoke:recurring-state": "bun run scripts/smoke/recurring-state-conformance.ts",
    "smoke:transaction-type": "bun run scripts/smoke/transaction-type-conformance.ts",
    "clean": "rm -rf dist coverage .bun-build",
    "pack:mcpb": "bun run scripts/pack-mcpb.ts",
    "pack:mcpb:write": "bun run scripts/sync-manifest.ts -- --write && bun run scripts/pack-mcpb.ts -- --write",
    "prepublishOnly": "bun run clean && bun run build && bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "classic-level": "^3.0.0",
    "protobufjs": "^8.6.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "latest",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.0.0",
    "graphql": "^16.14.1",
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.1"
  }
}
